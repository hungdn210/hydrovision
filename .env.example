# ==========================================================
# HydroVision Environment Configuration Template
# ==========================================================
# Copy this file to `.env` and fill in your details before running the app.

# [OPTIONAL] Gemini API Key for Heuristic AI Analysis
# Enabling this unlocks advanced narrative summaries in the Analysis Dock.
# Without this key, AI features gracefully degrade to deterministic statistical text fallbacks.
GEMINI_API_KEY=your_gemini_api_key_here

# [OPTIONAL] Flask Port Configuration
# By default, the application runs on port 5000.
# FLASK_RUN_PORT=5000
